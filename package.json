{
  "name": "zara-challenge",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Zara mobile phone catalog lab — React 18 + TypeScript + Vite",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,scss,css,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,scss,css,json,md}\"",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.config.unit.ts",
    "test:intg": "vitest run --config vitest.config.intg.ts",
    "test:all": "vitest run",
    "test:watch": "vitest",
    "test:watch:unit": "vitest --config vitest.config.unit.ts",
    "test:watch:intg": "vitest --config vitest.config.intg.ts",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "type-check": "tsc --noEmit",
    "verify": "tsc --noEmit && eslint . --max-warnings 0 && vitest run --passWithNoTests",
    "typedoc": "typedoc",
    "typedoc:watch": "typedoc --watch",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,css,scss,json,md}": "prettier --write",
    "src/**/*.{ts,tsx}": ["eslint --fix", "vitest related --run"]
  },
  "dependencies": {
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router-dom": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-jsx-a11y": "catalog:",
    "eslint-plugin-react": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-react-refresh": "catalog:",
    "eslint-plugin-vitest": "catalog:",
    "globals": "catalog:",
    "husky": "^9.1.7",
    "jsdom": "catalog:",
    "lint-staged": "^16.4.0",
    "prettier": "catalog:",
    "sass": "catalog:",
    "typedoc": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
