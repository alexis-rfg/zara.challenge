{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["./src"],
  "entryPointStrategy": "expand",
  "out": "typedoc",
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/node_modules/**",
    "**/dist/**",
    "**/env.d.ts"
  ],
  "excludePrivate": true,
  "excludeProtected": false,
  "excludeExternals": true,
  "includeVersion": true,
  "readme": "README.md",
  "plugin": [],
  "tsconfig": "./tsconfig.app.json",
  "name": "Zara Challenge Documentation",
  "navigationLinks": {
    "GitHub": "https://github.com/alexis-rfg/zara.challenge"
  },
  "sidebarLinks": {},
  "categorizeByGroup": true,
  "sort": ["source-order"],
  "visibilityFilters": {
    "protected": false,
    "private": false,
    "inherited": true,
    "external": false
  },
  "highlightLanguages": ["typescript", "javascript", "tsx", "jsx", "json", "css", "scss", "bash", "html"],
  "externalSymbolLinkMappings": {
    "typescript": {
      "Intl.NumberFormat": "https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/Intl/NumberFormat"
    },
    "zara-challenge": {
      "CACHE_TTL_MS": "#",
      "MAX_BUFFER_SIZE": "#"
    }
  }
}
